{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "AllowedHosts": "*",
  "Jwt": {
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  },
  "MinIO": {
    "UploadUrlTtlHours": 2
  },
  "ChannelSettings": {
    "MaxChannelsPerUser": 10
  },
  "VideoSettings": {
    "MaxTagsPerVideo": 10,
    "ReconciliationIntervalMinutes": 15
  },
  "Webhook": {
    "MinioUploadToken": "change-me-minio-upload-token"
  },
  "Api": {
    "BaseUrl": "http://localhost:5000"
  },
  "TrendingSettings": {
    "ViewCountWeight": 1.0,
    "LikeCountWeight": 2.0,
    "TimeDecayFactor": 1.5,
    "WindowHours": 48
  }
}
